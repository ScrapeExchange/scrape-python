        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "youtube",
    "scrape",
    "scrape.exchange"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "label": "Datasource",
        "current": {},
        "hide": 0
      },
      {
        "name": "job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "refresh": 2,
        "query": {
          "query": "label_values({job=~\"youtube_video|youtube_channel|youtube_rss\"}, job)",
          "refId": "StandardVariableQuery"
        },
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": "youtube_video|youtube_channel|youtube_rss",
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": false
        },
        "label": "Job"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "refresh": 2,
        "query": {
          "query": "label_values({job=~\"$job\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": false
        },
        "label": "Instance"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
